---
import { ArrowRight, Globe, MapPin, Users, Compass, Home as HomeIcon, Mountain, Quote } from 'lucide-astro';
import Layout from '../../layouts/Layout.astro';
import { getLocalizedPath } from '../../i18n/site';
import type { Locale } from '../../i18n/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const copy = locale === 'fr'
  ? {
      title: 'Accueil',
      description: 'SIGHT — Service d\'Information, d\'Orientation et d\'Hospitalité pour les Voyageurs. Connectez-vous avec des membres de Mensa Canada lors de votre visite.',
      heroBadge: 'Réseau d\'hospitalité pour Mensiens voyageurs',
      heroTitle: 'VOYAGEZ.',
      heroAccent: 'CONNECTEZ.',
      heroBody: 'Rencontrez des Mensiens locaux lors de votre visite au Canada. Conseils, hébergement et rencontres amicales vous attendent.',
      heroPrimary: 'Planifier votre visite',
      heroSecondary: 'Découvrir le programme',
      trustItems: ['50+ pays participants', '16 chapitres au Canada', 'Hôtes et coordonnateurs locaux'],
      stats: [
        { value: '50+', label: 'Pays participants' },
        { value: '1967', label: 'Année de fondation' },
        { value: '16', label: 'Chapitres au Canada' },
        { value: '6', label: 'Continents' },
      ],
      howTitle: 'Comment ça fonctionne',
      howSubtitle: 'Trois rôles, un réseau d\'hospitalité mondial',
      roles: [
        { step: '01', icon: 'compass', title: 'Coordinateur', description: 'Le coordinateur SIGHT de chaque pays reçoit les demandes des voyageurs et les met en contact avec les hôtes locaux.' },
        { step: '02', icon: 'home', title: 'Hôte', description: 'Les hôtes bénévoles offrent un café, une visite guidée, des conseils locaux ou même l\'hébergement aux voyageurs Mensiens.' },
        { step: '03', icon: 'users', title: 'Voyageur', description: 'Vous planifiez votre visite, contactez le coordinateur et profitez de l\'hospitalité des membres locaux.' },
      ],
      featuresTitle: 'Ce que SIGHT offre',
      featuresSubtitle: 'Un réseau d\'hospitalité unique pour les membres de Mensa',
      features: [
        { title: 'Rencontres locales', description: 'Un café, un repas ou une sortie avec des membres de Mensa de votre destination.', icon: 'users' },
        { title: 'Conseils de voyage', description: 'Découvrez les trésors cachés et les bonnes adresses connues des locaux.', icon: 'mapPin' },
        { title: 'Hébergement', description: 'Certains hôtes offrent un lit ou un canapé pour une ou deux nuits.', icon: 'home' },
        { title: 'Réseau mondial', description: 'Présent dans plus de 50 pays, SIGHT vous accompagne partout dans le monde.', icon: 'globe' },
      ],
      destinationsTitle: 'Destinations au Canada',
      destinationsSubtitle: 'Des Rocheuses aux côtes de l\'Atlantique, SIGHT vous connecte à travers le Canada',
      destinations: [
        { city: 'Vancouver', tagline: 'Montagnes & océan' },
        { city: 'Victoria', tagline: 'Capitale insulaire' },
        { city: 'Kelowna', tagline: 'Vignobles & lacs' },
        { city: 'Calgary', tagline: 'Porte des Rocheuses' },
        { city: 'Edmonton', tagline: 'Ville de festivals' },
        { city: 'Saskatoon', tagline: 'Joyau des prairies' },
        { city: 'Winnipeg', tagline: 'Cœur du continent' },
        { city: 'Toronto', tagline: 'Métropole canadienne' },
        { city: 'Ottawa', tagline: 'Capitale nationale' },
        { city: 'Kitchener', tagline: 'Innovation & technologie' },
        { city: 'London', tagline: 'Cité des forêts' },
        { city: 'Windsor', tagline: 'Ville frontalière' },
        { city: 'Sudbury', tagline: 'Porte du Nord' },
        { city: 'Montréal', tagline: 'Culture francophone' },
        { city: 'Québec', tagline: 'Charme historique' },
        { city: 'Halifax', tagline: 'Côte atlantique' },
      ],
      testimonialsTitle: 'Ce que disent les voyageurs',
      testimonials: [
        { quote: 'Mon hôte de Toronto m\'a fait découvrir des quartiers que je n\'aurais jamais trouvés seul. Une expérience incroyable!', author: 'Pierre L.', origin: 'France' },
        { quote: 'SIGHT m\'a permis de rencontrer des gens extraordinaires à Vancouver. Ils sont devenus de vrais amis.', author: 'Maria S.', origin: 'Espagne' },
        { quote: 'De Montréal à Halifax, chaque escale était enrichie par la générosité des hôtes SIGHT Canada.', author: 'Hans W.', origin: 'Allemagne' },
      ],
      ctaTitle: 'Prêt à explorer le Canada?',
      ctaBody: 'Remplissez notre formulaire et nous vous mettrons en contact avec des membres de Mensa dans les villes que vous visiterez.',
      ctaPrimary: 'Planifier votre visite',
      ctaSecondary: 'Voir les contacts',
    }
  : locale === 'es'
    ? {
        title: 'Inicio',
        description: 'SIGHT — Servicio de Información, Orientación y Hospitalidad para Viajeros. Conéctese con miembros de Mensa Canada durante su visita.',
        heroBadge: 'Red de hospitalidad para viajeros de Mensa',
        heroTitle: 'VIAJE.',
        heroAccent: 'CONECTE.',
        heroBody: 'Conozca miembros locales de Mensa durante su visita a Canadá. Consejos, alojamiento y encuentros amistosos le esperan.',
        heroPrimary: 'Planificar su viaje',
        heroSecondary: 'Descubrir el programa',
        trustItems: ['50+ países participantes', '16 capítulos en Canadá', 'Anfitriones y coordinadores locales'],
        stats: [
          { value: '50+', label: 'Países participantes' },
          { value: '1967', label: 'Año de fundación' },
          { value: '16', label: 'Capítulos en Canadá' },
          { value: '6', label: 'Continentes' },
        ],
        howTitle: 'Cómo funciona',
        howSubtitle: 'Tres roles, una red de hospitalidad global',
        roles: [
          { step: '01', icon: 'compass', title: 'Coordinador', description: 'El coordinador SIGHT de cada país recibe las solicitudes de los viajeros y los conecta con los anfitriones locales.' },
          { step: '02', icon: 'home', title: 'Anfitrión', description: 'Los anfitriones voluntarios ofrecen un café, un recorrido, consejos locales o incluso alojamiento a los viajeros Mensanos.' },
          { step: '03', icon: 'users', title: 'Viajero', description: 'Usted planifica su visita, contacta al coordinador y disfruta de la hospitalidad de los miembros locales.' },
        ],
        featuresTitle: 'Lo que SIGHT ofrece',
        featuresSubtitle: 'Una red de hospitalidad única para miembros de Mensa',
        features: [
          { title: 'Encuentros locales', description: 'Un café, una comida o una salida con miembros de Mensa en su destino.', icon: 'users' },
          { title: 'Consejos de viaje', description: 'Descubra los tesoros ocultos y los buenos lugares conocidos por los locales.', icon: 'mapPin' },
          { title: 'Alojamiento', description: 'Algunos anfitriones ofrecen una cama o un sofá por una o dos noches.', icon: 'home' },
          { title: 'Red mundial', description: 'Presente en más de 50 países, SIGHT le acompaña por todo el mundo.', icon: 'globe' },
        ],
        destinationsTitle: 'Destinos en Canadá',
        destinationsSubtitle: 'De las Rocosas a las costas del Atlántico, SIGHT lo conecta a lo largo de Canadá',
        destinations: [
          { city: 'Vancouver', tagline: 'Montañas y océano' },
          { city: 'Victoria', tagline: 'Capital insular' },
          { city: 'Kelowna', tagline: 'Viñedos y lagos' },
          { city: 'Calgary', tagline: 'Puerta de las Rocosas' },
          { city: 'Edmonton', tagline: 'Ciudad de festivales' },
          { city: 'Saskatoon', tagline: 'Joya de las praderas' },
          { city: 'Winnipeg', tagline: 'Corazón del continente' },
          { city: 'Toronto', tagline: 'Metrópolis canadiense' },
          { city: 'Ottawa', tagline: 'Capital nacional' },
          { city: 'Kitchener', tagline: 'Innovación y tecnología' },
          { city: 'London', tagline: 'Ciudad del bosque' },
          { city: 'Windsor', tagline: 'Ciudad fronteriza' },
          { city: 'Sudbury', tagline: 'Puerta del norte' },
          { city: 'Montréal', tagline: 'Cultura francófona' },
          { city: 'Québec', tagline: 'Encanto histórico' },
          { city: 'Halifax', tagline: 'Costa atlántica' },
        ],
        testimonialsTitle: 'Lo que dicen los viajeros',
        testimonials: [
          { quote: 'Mi anfitrión en Toronto me mostró barrios que nunca habría encontrado solo. ¡Una experiencia increíble!', author: 'Pierre L.', origin: 'Francia' },
          { quote: 'SIGHT me permitió conocer gente extraordinaria en Vancouver. Se convirtieron en verdaderos amigos.', author: 'Maria S.', origin: 'España' },
          { quote: 'De Montreal a Halifax, cada parada fue enriquecida por la generosidad de los anfitriones SIGHT Canadá.', author: 'Hans W.', origin: 'Alemania' },
        ],
        ctaTitle: '¿Listo para explorar Canadá?',
        ctaBody: 'Complete nuestro formulario y le conectaremos con miembros de Mensa en las ciudades que visitará.',
        ctaPrimary: 'Planificar su viaje',
        ctaSecondary: 'Ver contactos',
      }
    : {
        title: 'Home',
        description: 'SIGHT — Service of Information, Guidance and Hospitality to Travellers. Connect with Mensa Canada members during your visit.',
        heroBadge: 'Hospitality network for travelling Mensans',
        heroTitle: 'TRAVEL.',
        heroAccent: 'CONNECT.',
        heroBody: 'Meet local Mensa members when you visit Canada. Insider tips, accommodation, and friendly meetups await.',
        heroPrimary: 'Plan Your Trip',
        heroSecondary: 'Discover the Program',
        trustItems: ['50+ participating countries', '16 chapters in Canada', 'Local hosts and coordinators'],
        stats: [
          { value: '50+', label: 'Participating countries' },
          { value: '1967', label: 'Year founded' },
          { value: '16', label: 'Chapters in Canada' },
          { value: '6', label: 'Continents' },
        ],
        howTitle: 'How It Works',
        howSubtitle: 'Three roles, one global hospitality network',
        roles: [
          { step: '01', icon: 'compass', title: 'Coordinator', description: 'Each country\'s SIGHT coordinator receives traveller requests and connects them with local hosts.' },
          { step: '02', icon: 'home', title: 'Host', description: 'Volunteer hosts offer coffee, a guided tour, local tips, or even overnight accommodation to fellow Mensans.' },
          { step: '03', icon: 'users', title: 'Traveller', description: 'You plan your visit, contact the coordinator, and enjoy hospitality from local members.' },
        ],
        featuresTitle: 'What SIGHT Offers',
        featuresSubtitle: 'A unique hospitality network for Mensa members',
        features: [
          { title: 'Local Meetups', description: 'Share a coffee, a meal, or a day out with Mensa members at your destination.', icon: 'users' },
          { title: 'Travel Tips', description: 'Discover hidden gems and local favourites known only to residents.', icon: 'mapPin' },
          { title: 'Accommodation', description: 'Some hosts offer a spare bed or couch for a night or two.', icon: 'home' },
          { title: 'Global Network', description: 'Active in 50+ countries, SIGHT connects you with Mensans worldwide.', icon: 'globe' },
        ],
        destinationsTitle: 'Canadian Destinations',
        destinationsSubtitle: 'From the Rockies to the Atlantic coast, SIGHT connects you across Canada',
        destinations: [
          { city: 'Vancouver', tagline: 'Mountains & ocean' },
          { city: 'Victoria', tagline: 'Island capital' },
          { city: 'Kelowna', tagline: 'Wine & lakes' },
          { city: 'Calgary', tagline: 'Gateway to the Rockies' },
          { city: 'Edmonton', tagline: 'Festival city' },
          { city: 'Saskatoon', tagline: 'Prairie gem' },
          { city: 'Winnipeg', tagline: 'Heart of the continent' },
          { city: 'Toronto', tagline: 'Canadian metropolis' },
          { city: 'Ottawa', tagline: 'National capital' },
          { city: 'Kitchener', tagline: 'Tech & innovation' },
          { city: 'London', tagline: 'Forest city' },
          { city: 'Windsor', tagline: 'Border city' },
          { city: 'Sudbury', tagline: 'Northern gateway' },
          { city: 'Montréal', tagline: 'Francophone culture' },
          { city: 'Québec', tagline: 'Historic charm' },
          { city: 'Halifax', tagline: 'Atlantic coast' },
        ],
        testimonialsTitle: 'What Travellers Say',
        testimonials: [
          { quote: 'My Toronto host showed me neighbourhoods I never would have found on my own. An incredible experience!', author: 'Pierre L.', origin: 'France' },
          { quote: 'SIGHT let me meet extraordinary people in Vancouver. They became true friends.', author: 'Maria S.', origin: 'Spain' },
          { quote: 'From Montréal to Halifax, every stop was enriched by the generosity of SIGHT Canada hosts.', author: 'Hans W.', origin: 'Germany' },
        ],
        ctaTitle: 'Ready to Explore Canada?',
        ctaBody: 'Fill out our form and we\'ll connect you with Mensa members in the cities you\'re visiting.',
        ctaPrimary: 'Plan Your Trip',
        ctaSecondary: 'View Contacts',
      };

const iconMap = { compass: Compass, home: HomeIcon, users: Users, mapPin: MapPin, globe: Globe };

/* Gradient fallbacks per city – used when custom photos are not present */
const destinationGradients: Record<string, string> = {
  Vancouver: 'linear-gradient(135deg, #1e5c7b, #2d7251)',
  Victoria: 'linear-gradient(135deg, #2d5c4a, #4a7b6b)',
  Kelowna: 'linear-gradient(135deg, #7b5c2d, #5c7b3d)',
  Calgary: 'linear-gradient(135deg, #4a3d5c, #5c7b8b)',
  Edmonton: 'linear-gradient(135deg, #3d4a5c, #5c6b7b)',
  Saskatoon: 'linear-gradient(135deg, #5c6b3d, #7b8b4a)',
  Winnipeg: 'linear-gradient(135deg, #3d5c6b, #2d4a5c)',
  Toronto: 'linear-gradient(135deg, #3a4055, #5a6275)',
  Ottawa: 'linear-gradient(135deg, #6b2d2d, #4a5c6b)',
  Kitchener: 'linear-gradient(135deg, #3d5c3d, #5c7b5c)',
  London: 'linear-gradient(135deg, #4a5c3d, #3d7b4a)',
  Windsor: 'linear-gradient(135deg, #5c4a3d, #7b6b5c)',
  Sudbury: 'linear-gradient(135deg, #2d4a3d, #4a6b5c)',
  'Montréal': 'linear-gradient(135deg, #5c3d3d, #7b5c5c)',
  'Québec': 'linear-gradient(135deg, #6b5a2d, #8b7a4d)',
  Halifax: 'linear-gradient(135deg, #2d3d5c, #3d5c7b)',
};
---

<Layout title={copy.title} description={copy.description} locale={locale} routeKey="home">
  <!-- Hero with background image -->
  <section
    class="image-hero"
    style={`background: url('/images/hero-home.jpg') center/cover no-repeat, url('/images/hero-home.svg') center/cover no-repeat, linear-gradient(135deg, #0D2237, #1A3A5C 50%, #7C2A39);`}
  >
    <div class="absolute -left-20 top-20 h-72 w-72 rounded-full bg-primary/20 blur-3xl" style="z-index:1;"></div>
    <div class="absolute -right-16 bottom-16 h-56 w-56 rounded-full bg-accent/12 blur-3xl" style="z-index:1;"></div>

    <div class="page-container">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mb-6 inline-flex items-center rounded-full border border-text-inverse/12 bg-text-inverse/5 px-4 py-2 text-[0.72rem] font-semibold uppercase tracking-[0.2em] text-text-inverse/72 backdrop-blur-sm">
          {copy.heroBadge}
        </p>
        <h1 class="font-heading text-6xl font-black uppercase tracking-[-0.05em] text-text-inverse md:text-7xl lg:text-8xl">
          {copy.heroTitle}<br />
          <span class="text-primary">{copy.heroAccent}</span>
        </h1>
        <p class="mx-auto mt-6 max-w-xl text-lg font-medium leading-relaxed text-text-inverse/72 md:text-xl">
          {copy.heroBody}
        </p>
        <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
          <a href={getLocalizedPath(locale, 'plan')} class="btn-primary">
            {copy.heroPrimary} <ArrowRight class="w-4 h-4" />
          </a>
          <a href={getLocalizedPath(locale, 'program')} class="btn-secondary !border-text-inverse/18 !bg-transparent !text-text-inverse hover:!border-text-inverse hover:!bg-text-inverse hover:!text-surface-dark">
            {copy.heroSecondary}
          </a>
        </div>
        <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-[0.74rem] font-semibold uppercase tracking-[0.16em] text-text-inverse/48">
          {copy.trustItems.map((item) => (
            <span class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              {item}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Strip -->
  <section class="border-b border-border bg-surface-cool/60 py-10">
    <div class="page-container">
      <div class="grid grid-cols-2 gap-8 text-center md:grid-cols-4">
        {copy.stats.map((stat) => (
          <div>
            <div class="stat-value">{stat.value}</div>
            <div class="stat-label">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="relative py-section">
    <div class="home-section-atmosphere absolute inset-0"></div>
    <div class="page-container relative">
      <div class="mb-14 text-center">
        <span class="section-kicker">{copy.howTitle}</span>
        <h2 class="section-title">{copy.howTitle}</h2>
        <p class="section-subtitle mx-auto">{copy.howSubtitle}</p>
      </div>

      <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
        {copy.roles.map((role) => {
          const IconComponent = iconMap[role.icon as keyof typeof iconMap];
          return (
            <div class="surface-panel relative overflow-hidden px-7 py-8">
              <div class="mb-5 flex items-center gap-4">
                <div class="flex h-12 w-12 items-center justify-center rounded-[0.6rem] bg-primary/10 text-primary">
                  <IconComponent class="w-5 h-5" />
                </div>
                <span class="font-heading text-3xl font-black text-primary/20">{role.step}</span>
              </div>
              <h3 class="mb-3 font-heading text-xl font-bold uppercase tracking-[-0.02em] text-secondary">{role.title}</h3>
              <p class="text-[0.92rem] leading-relaxed text-text-secondary">{role.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Destinations -->
  <section class="py-section bg-surface-cool/50">
    <div class="page-container">
      <div class="mb-14 text-center">
        <span class="section-kicker"><Mountain class="inline w-3.5 h-3.5 -mt-0.5 mr-1" />{copy.destinationsTitle}</span>
        <h2 class="section-title">{copy.destinationsTitle}</h2>
        <p class="section-subtitle mx-auto">{copy.destinationsSubtitle}</p>
      </div>

      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        {copy.destinations.map((dest) => {
          const slug = dest.city.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/\s+/g, '-');
          const gradient = destinationGradients[dest.city] || 'linear-gradient(135deg, #C22A37, #17324D)';
          return (
            <div
              class="destination-card aspect-[3/2]"
              style={`background: url('/images/destinations/${slug}.jpg') center/cover no-repeat, url('/images/destinations/${slug}.svg') center/cover no-repeat, ${gradient};`}
            >
              <div class="destination-card-content">
                <h3 class="font-heading text-2xl font-bold text-white">{dest.city}</h3>
                <p class="text-sm text-white/72">{dest.tagline}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-section">
    <div class="page-container">
      <div class="mb-14 text-center">
        <h2 class="section-title">{copy.featuresTitle}</h2>
        <p class="section-subtitle mx-auto">{copy.featuresSubtitle}</p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {copy.features.map((feature) => {
          const IconComponent = iconMap[feature.icon as keyof typeof iconMap];
          return (
            <div class="outlined-panel px-6 py-7 text-center">
              <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-primary/8 text-primary">
                <IconComponent class="w-6 h-6" />
              </div>
              <h3 class="mb-2 font-heading text-lg font-bold uppercase tracking-[-0.02em] text-secondary">{feature.title}</h3>
              <p class="text-sm leading-relaxed text-text-secondary">{feature.description}</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-section bg-surface-cool/50">
    <div class="page-container">
      <div class="mb-14 text-center">
        <h2 class="section-title">{copy.testimonialsTitle}</h2>
      </div>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
        {copy.testimonials.map((t) => (
          <div class="testimonial-card">
            <Quote class="w-8 h-8 text-primary/25 mb-4" />
            <p class="testimonial-quote">{t.quote}</p>
            <div class="mt-6 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10 text-primary font-heading font-bold text-sm">
                {t.author.charAt(0)}
              </div>
              <div>
                <p class="text-sm font-semibold text-text-primary">{t.author}</p>
                <p class="text-xs text-text-muted">{t.origin}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-section">
    <div class="page-container">
      <div class="relative overflow-hidden rounded-[2rem] bg-surface-dark px-8 py-14 text-text-inverse md:px-14 md:py-18">
        <div class="footer-cta-atmosphere absolute inset-0"></div>
        <div class="absolute -right-12 top-6 h-40 w-40 rounded-full bg-primary/25 blur-3xl"></div>
        <div class="absolute bottom-0 left-12 h-24 w-24 rounded-full bg-accent/15 blur-2xl"></div>

        <div class="relative flex flex-col gap-8 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-xl">
            <h2 class="font-heading text-4xl font-semibold leading-none text-text-inverse md:text-5xl">{copy.ctaTitle}</h2>
            <p class="mt-5 text-base leading-relaxed text-text-inverse/72 md:text-lg">{copy.ctaBody}</p>
          </div>
          <div class="flex flex-col gap-4 sm:flex-row">
            <a href={getLocalizedPath(locale, 'plan')} class="btn-accent">{copy.ctaPrimary}</a>
            <a href={getLocalizedPath(locale, 'contacts')} class="btn-secondary !border-text-inverse/18 !bg-transparent !text-text-inverse hover:!border-text-inverse hover:!bg-text-inverse hover:!text-surface-dark">
              {copy.ctaSecondary}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
